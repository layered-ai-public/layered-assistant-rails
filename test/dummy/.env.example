# Ollama – local models with OpenAI-compatible API
# Download and run from: https://ollama.com/
# OLLAMA_API_URL="http://localhost:11434/v1"
# OLLAMA_API_KEY=""

# LM Studio – local models with OpenAI-compatible API
# Download and run from: https://lmstudio.ai/
# LM_STUDIO_API_URL="http://localhost:1234/v1"
# LM_STUDIO_API_KEY=""

# OpenRouter - The Unified Interface For LLMs
# Access 300+ models from 1 unified API gateway
# Get from: https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=""

# Groq - The AI inference platform built for developers
# Fast responses, scalable performance, and costs you can plan for
# Get from: https://console.groq.com/keys
# GROQ_API_KEY=""

# Mistral - Frontier AI. In your hands.
# Get from: https://admin.mistral.ai/organization/api-keys
# MISTRAL_API_KEY=""

# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=""

# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=""

# Get from: https://aistudio.google.com/api-keys
# GEMINI_API_KEY=""

# Log errors and LLM API HTTP request body to stdout (yes / no, default: no to avoid logging sensitive data)
# LAYERED_ASSISTANT_LOG_ERRORS="no"

# Add ngrok domain to allow local development with ngrok
# NGROK_DOMAIN="your-ngrok-domain.ngrok.io"
