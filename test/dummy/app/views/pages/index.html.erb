<% content_for :l_ui_body_class do %>l-ui-body--always-show-navigation<% end %>

<h1>layered-assistant-rails (v<%= Layered::Assistant::VERSION %>)</h1>

<p class="l-ui-utility--mt-md">
  <%= Gem.loaded_specs["layered-assistant-rails"].description %>
</p>

<!-- MailerLite Universal -->
