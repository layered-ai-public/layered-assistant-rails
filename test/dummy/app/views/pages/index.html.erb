<% content_for :l_ui_body_class do %>l-ui-body--always-show-navigation<% end %>

<%= l_ui_breadcrumbs do %>
  <%= l_ui_breadcrumb_item "#{gem_spec.name} (v#{gem_spec.version.to_s})" %>
<% end %>
<h1>Home</h1>

<p class="l-ui-utility--mt-md">
  <%= gem_spec.description %>
</p>

<%= render "socials" %>

<h2 class="l-ui-utility--mt-xl">Features</h2>
<div class="l-ui-container--grid l-ui-utility--mt-lg">
  <div class="l-ui-surface">
    <div class="flex items-center gap-2">
      <%= image_tag "icon_cloud.svg", class: "l-ui-icon--md dark:invert", alt: "Cloud icon representing multi-provider support" %>
      <h3>Multi-provider and model support</h3>
    </div>
    <p class="l-ui-utility--mt-sm">Use cloud (Anthropic, OpenAI, Gemini, Mistral, Groq, OpenRouter) or local (Ollama or LM Studio) providers with configurable models.</p>
  </div>
  <div class="l-ui-surface">
    <div class="flex items-center gap-2">
      <%= image_tag "icon_arrows.svg", class: "l-ui-icon--md dark:invert", alt: "Back and forward arrows icon representing streaming responses" %>
      <h3>Streaming responses</h3>
    </div>
    <p class="l-ui-utility--mt-sm">Real-time streaming via Turbo Streams for a responsive chat experience with intelligent fade-in for completed markdown sections.</p>
  </div>
  <div class="l-ui-surface">
    <div class="flex items-center gap-2">
      <%= image_tag "icon_chat.svg", class: "l-ui-icon--md dark:invert", alt: "Chat bubbles icon representing conversation interface" %>
      <h3>Conversation UI</h3>
    </div>
    <p class="l-ui-utility--mt-sm">Full conversation interface with message history, model selection, and a slide-out panel mode.</p>
  </div>
  <div class="l-ui-surface">
    <div class="flex items-center gap-2">
      <%= image_tag "icon_lock.svg", class: "l-ui-icon--md dark:invert", alt: "Padlock icon representing encrypted secrets" %>
      <h3>Encrypted secrets</h3>
    </div>
    <p class="l-ui-utility--mt-sm">API keys are encrypted at rest using Active Record Encryption by default.</p>
  </div>
  <div class="l-ui-surface">
    <div class="flex items-center gap-2">
      <%= image_tag "icon_person.svg", class: "l-ui-icon--md dark:invert", alt: "Person icon representing personas" %>
      <h3>Personas</h3>
    </div>
    <p class="l-ui-utility--mt-sm">Define custom personas with system prompts to tailor assistant behaviour for different use cases.</p>
  </div>
  <div class="l-ui-surface">
    <div class="flex items-center gap-2">
      <%= image_tag "icon_bolt.svg", class: "l-ui-icon--md dark:invert", alt: "Lightning bolt icon representing skills" %>
      <h3>Skills</h3>
    </div>
    <p class="l-ui-utility--mt-sm">Attach reusable skills to extend assistant capabilities with structured instructions.</p>
  </div>
  <div class="l-ui-surface">
    <div class="flex items-center gap-2">
      <%= image_tag "icon_spanner.svg", class: "l-ui-icon--md dark:invert", alt: "Spanner icon representing tool use" %>
      <h3>Tool use</h3>
    </div>
    <p class="l-ui-utility--mt-sm">Connect assistants to external tools and APIs with configurable tool definitions and execution callbacks.</p>
  </div>
  <div class="l-ui-surface">
    <div class="flex items-center gap-2">
      <%= image_tag "icon_globe.svg", class: "l-ui-icon--md dark:invert", alt: "Globe icon representing embeddable assistant" %>
      <h3>Embeddable</h3>
    </div>
    <p class="l-ui-utility--mt-sm">Embed public assistants on any website and access the conversations from your Rails backend.</p>
  </div>
</div>

<h2 class="l-ui-utility--mt-xl">Requirements</h2>
<ul class="l-ui-list l-ui-utility--mt-md">
  <li>Ruby on Rails >= 8.0</li>
  <li><code>layered-ui-rails</code> gem</li>
</ul>

<h2 class="l-ui-utility--mt-xl">Installation</h2>
<p class="l-ui-utility--mt-md">Add to your Gemfile:</p>
<code class="l-ui-surface l-ui-utility--mt-md">gem "layered-assistant-rails"</code>
<p class="l-ui-utility--mt-lg">Then run:</p>
<code class="l-ui-surface l-ui-utility--mt-md">bundle install</code>

<h2 class="l-ui-utility--mt-xl">Setup</h2>
<%= render "layered/assistant/setup/setup" %>

<h2 class="l-ui-utility--mt-xl">Configuration</h2>
<p class="l-ui-utility--mt-md">Optional settings for <code>config/initializers/layered_assistant.rb</code>:</p>

<table class="l-ui-table l-ui-utility--mt-lg">
  <caption class="l-ui-sr-only">Configuration options</caption>
  <thead class="l-ui-table__header">
    <tr>
      <th scope="col" class="l-ui-table__header-cell">Option</th>
      <th scope="col" class="l-ui-table__header-cell">Default</th>
      <th scope="col" class="l-ui-table__header-cell">Description</th>
    </tr>
  </thead>
  <tbody class="l-ui-table__body">
    <tr>
      <th scope="row" class="l-ui-table__cell--primary"><code>log_errors</code></th>
      <td class="l-ui-table__cell"><code>false</code></td>
      <td class="l-ui-table__cell">Log API errors to stdout.</td>
    </tr>
    <tr>
      <th scope="row" class="l-ui-table__cell--primary"><code>api_request_timeout</code></th>
      <td class="l-ui-table__cell"><code>210</code></td>
      <td class="l-ui-table__cell">Total timeout in seconds for API requests, including the full streaming response. Increase for models with high max_tokens limits or slow providers.</td>
    </tr>
    <tr>
      <th scope="row" class="l-ui-table__cell--primary"><code>skip_db_encryption</code></th>
      <td class="l-ui-table__cell"><code>false</code></td>
      <td class="l-ui-table__cell">Disable Active Record Encryption on <code>Provider#secret</code>. Development/test only.</td>
    </tr>
  </tbody>
</table>
