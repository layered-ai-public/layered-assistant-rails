<% if @error %>
  <%= turbo_stream.append_all ".#{dom_id(@conversation)}_messages" do %>
    <div class="l-ui-notice l-ui-notice--error l-ui-mb-0" role="alert"><%= @error %></div>
  <% end %>
<% end %>

<%= turbo_stream.replace "public-composer-form" do %>
  <%= render "layered/assistant/public/messages/composer", conversation: @conversation, responding: @error.nil? %>
<% end %>
