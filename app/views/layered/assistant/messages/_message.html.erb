<% if message.assistant? && message.content.blank? && message.tool_calls.present? %>
  <div id="<%= dom_id(message) %>" class="<%= dom_id(message) %>" hidden></div>
<% elsif message.tool? %>
  <% tool_call = tool_call_for(message) %>
  <%= tag.div id: dom_id(message), data: { created_at: (message.created_at.to_f * 1000).to_i }, class: "#{dom_id(message)} l-ui-message" do %>
    <div class="l-ui-message__bubble">
      <details class="l-ui-surface--collapsible-active l-ui-surface--sm">
        <summary class="l-ui-surface__summary">
          <span><strong>Tool:</strong> <%= tool_call ? tool_call["name"] : "unknown" %></span>
          <%= image_tag "layered_ui/icon_chevron_right.svg", alt: "", class: "l-ui-icon--sm l-ui-surface__chevron", aria: { hidden: true } %>
        </summary>
        <div class="l-ui-surface__content l-ui-markdown">
          <% if tool_call && tool_call["input"].present? %>
            <p>Input:</p>
            <pre><code><%= JSON.pretty_generate(tool_call["input"]) %></code></pre>
          <% end %>
          <% if message.content.present? %>
            <p>Output:</p>
            <pre><code><%= message.content %></code></pre>
          <% end %>
        </div>
      </details>
      <div class="l-ui-message__footer">
        <span class="l-ui-message__timestamp"><%= message.created_at.to_fs(:short) %></span>
      </div>
    </div>
  <% end %>
<% else %>
<%= tag.div id: dom_id(message), data: { created_at: (message.created_at.to_f * 1000).to_i }, class: "#{dom_id(message)} #{message.user? ? "l-ui-message--sent" : "l-ui-message"}" do %>
  <div class="l-ui-message__bubble">
    <% unless message.user? %>
      <div class="l-ui-message__author"><%= message.role.capitalize %></div>
    <% end %>
    <div class="<%= dom_id(message) %>_body l-ui-message__body<%= " l-ui-markdown" unless message.assistant? && message.content.blank? && !message.stopped? %>">
      <% if message.assistant? && message.content.blank? && !message.stopped? %>
        <div class="l-ui-typing-indicator" role="status" aria-label="Assistant is typing">
          <span class="l-ui-typing-indicator__dot"></span>
          <span class="l-ui-typing-indicator__dot"></span>
          <span class="l-ui-typing-indicator__dot"></span>
        </div>
      <% else %>
        <%= render_message_content(message) %>
      <% end %>
      <% if message.stopped? %>
        <div class="l-ui-notice--warning" role="status">The response was stopped</div>
      <% end %>
    </div>
    <div class="l-ui-message__footer">
      <% if message.model %>
        <% title = message_metadata_title(message) %>
        <span class="l-ui-message__metadata"<%= " title=\"#{title}\"".html_safe if title.present? %>><%= message.model.name %></span>
      <% end %>
      <span class="l-ui-message__timestamp"><%= message.created_at.to_fs(:short) %></span>
    </div>
  </div>
<% end %>
<% end %>
